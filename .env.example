# Copy to .env for local development. Never commit the real .env.

# Host ports docker-compose.yml exposes infra on — override any of these if the default
# already conflicts with something else running on your machine (docker-compose.yml reads
# them via ${VAR:-default} substitution, so leaving them unset is fine on a clean machine).
# If you change POSTGRES_PORT/RABBITMQ_PORT/etc., update the *_URL values below to match.
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101

# Postgres (hot store + events/audit store)
DATABASE_URL=postgres://kizashi:kizashi@localhost:5432/kizashi

# RabbitMQ (message bus)
RABBITMQ_URL=amqp://kizashi:kizashi@localhost:5672/%2f
# RabbitMQ management HTTP API (observability's pipeline backlog view, ADR-0012)
RABBITMQ_MANAGEMENT_URL=http://kizashi:kizashi@localhost:15672

# ClickHouse (aggregate/analytics store)
# Credentials are embedded (HTTP basic auth via userinfo) since ClickHouse's HTTP interface
# rejects anonymous/default-user requests once CLICKHOUSE_USER/PASSWORD are set on the server.
CLICKHOUSE_URL=http://kizashi:kizashi@localhost:8123
CLICKHOUSE_USER=kizashi
CLICKHOUSE_PASSWORD=kizashi
CLICKHOUSE_DB=kizashi

# Auth
AUTH_JWT_SECRET=change-me-in-production
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=
# Standard OIDC-compliant provider config. GENERIC_OAUTH_ISSUER_URL is documentation of which
# provider this is; auth-service does not (yet) perform OIDC discovery against
# {issuer}/.well-known/openid-configuration, so the three endpoint URLs are explicit for v1
# (ADR-0009).
GENERIC_OAUTH_ISSUER_URL=
GENERIC_OAUTH_CLIENT_ID=
GENERIC_OAUTH_CLIENT_SECRET=
GENERIC_OAUTH_AUTH_URL=
GENERIC_OAUTH_TOKEN_URL=
GENERIC_OAUTH_USERINFO_URL=
GENERIC_OAUTH_REDIRECT_URL=

# Query Gateway internal API (auth-service mints sessions through this, per ADR-0008/0009)
QUERY_GATEWAY_URL=http://localhost:8083
INTERNAL_API_SECRET=change-me-in-production

# Azure AI Foundry / ML (analysis-service)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=

# Blob / archival (retention-service, ADR-0011). S3_ENDPOINT_URL overrides the AWS SDK's
# default endpoint resolution to point at a self-hosted S3-compatible target (MinIO in
# docker-compose for local dev/CI); leave it unset to talk to real AWS S3.
AZURE_STORAGE_CONNECTION_STRING=
S3_ENDPOINT_URL=http://localhost:9100
AWS_S3_BUCKET=kizashi-archive
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=kizashi
AWS_SECRET_ACCESS_KEY=kizashi-minio-dev
# ingestion-service base URL (retention-service sweeps/reimports through it, ADR-0011)
INGESTION_SERVICE_URL=http://localhost:8082

# Console UI (ADR-0014) — the backend URLs it proxies authenticated requests to
AUTH_SERVICE_URL=http://localhost:8089
CONFIG_ADMIN_SERVICE_URL=http://localhost:8090
OBSERVABILITY_URL=http://localhost:8092

# Service bind addresses
BIND_ADDR=0.0.0.0:8080

RUST_LOG=info
