# Copy to .env for local development. Never commit the real .env.

# Host ports docker-compose.yml exposes infra on — override any of these if the default
# already conflicts with something else running on your machine (docker-compose.yml reads
# them via ${VAR:-default} substitution, so leaving them unset is fine on a clean machine).
# If you change POSTGRES_PORT/RABBITMQ_PORT/etc., update the *_URL values below to match.
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101

# Postgres (hot store + events/audit store). This DATABASE_URL is used only by things run
# directly on the host -- `cargo test`, `cargo run`, manual psql -- never by the docker-compose
# services themselves (each hardcodes its own postgres://.../kizashi in docker-compose.yml,
# unaffected by this variable). Deliberately points at a separate `kizashi_test` database
# (created by scripts/bootstrap.sh), not `kizashi`, so running tests locally never writes
# leftover fixtures into the same database the live stack and Console UI actually use --
# CI already gets this isolation for free via a fresh ephemeral Postgres container per run;
# this is the local-dev-loop equivalent.
DATABASE_URL=postgres://kizashi:kizashi@localhost:5432/kizashi_test

# RabbitMQ (message bus)
RABBITMQ_URL=amqp://kizashi:kizashi@localhost:5672/%2f
# RabbitMQ management HTTP API (observability's pipeline backlog view, ADR-0012)
RABBITMQ_MANAGEMENT_URL=http://kizashi:kizashi@localhost:15672

# ClickHouse (aggregate/analytics store)
# Credentials are embedded (HTTP basic auth via userinfo) since ClickHouse's HTTP interface
# rejects anonymous/default-user requests once CLICKHOUSE_USER/PASSWORD are set on the server.
CLICKHOUSE_URL=http://kizashi:kizashi@localhost:8123
CLICKHOUSE_USER=kizashi
CLICKHOUSE_PASSWORD=kizashi
CLICKHOUSE_DB=kizashi

# Auth
AUTH_JWT_SECRET=change-me-in-production
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=
# Standard OIDC-compliant provider config. GENERIC_OAUTH_ISSUER_URL is documentation of which
# provider this is; auth-service does not (yet) perform OIDC discovery against
# {issuer}/.well-known/openid-configuration, so the three endpoint URLs are explicit for v1
# (ADR-0009).
GENERIC_OAUTH_ISSUER_URL=
GENERIC_OAUTH_CLIENT_ID=
GENERIC_OAUTH_CLIENT_SECRET=
GENERIC_OAUTH_AUTH_URL=
GENERIC_OAUTH_TOKEN_URL=
GENERIC_OAUTH_USERINFO_URL=
GENERIC_OAUTH_REDIRECT_URL=

# Query Gateway internal API (auth-service mints sessions through this, per ADR-0008/0009)
QUERY_GATEWAY_URL=http://localhost:8083
# Shared secret required on X-Internal-Secret by every service that trusts X-Role/X-Tenant-Id/
# X-Username (config-admin-service, trigger-engine, auth-service, retention-service) and sent
# automatically by the Console UI and action-executor on every backend call (ADR-0009, ADR-0044).
INTERNAL_API_SECRET=change-me-in-production

# AES-256-GCM key (config-admin-service, ADR-0058) encrypting analysis_configs.api_key at rest --
# a tenant's AI provider credential was previously stored in plaintext. Must be a base64-encoded
# 32-byte value; generate one with `openssl rand -base64 32`. Losing/rotating this key makes
# every existing encrypted api_key unrecoverable, so treat it like any other production secret.
CONFIG_ENCRYPTION_KEY=change-me-to-a-real-base64-32-byte-key-in-production

# Console UI session cookie hardening: set to "true" only behind a real TLS-terminating
# deployment -- a Secure cookie is silently dropped by browsers over plain HTTP, which would
# break every login in local/dev.
COOKIE_SECURE=false

# Console UI sliding idle-session timeout, in minutes. Any activity resets the clock; a session
# left idle longer than this is signed out automatically instead of living forever.
SESSION_IDLE_TIMEOUT_MINUTES=30

# Azure AI Foundry / ML (analysis-service)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=

# Optional alternate OpenAI-compatible analysis model. When configured, transient failures from
# the primary model (timeouts, overload/rate-limit responses, and upstream 5xx responses) are
# attempted once against this endpoint/model before the normalized message is retried or
# dead-lettered. Keep the fallback model materially different from the primary model.
# Leave these blank to let scripts/run-local.sh auto-detect Ollama on localhost:11434.
# For Docker, use an address reachable from the container (for example an Ollama host service).
ANALYSIS_FALLBACK_ENDPOINT=
ANALYSIS_FALLBACK_MODEL=
ANALYSIS_FALLBACK_API_KEY=
ANALYSIS_OPENAI_CONCURRENCY=4

# Blob / archival (retention-service, ADR-0011). S3_ENDPOINT_URL overrides the AWS SDK's
# default endpoint resolution to point at a self-hosted S3-compatible target (MinIO in
# docker-compose for local dev/CI); leave it unset to talk to real AWS S3.
AZURE_STORAGE_CONNECTION_STRING=
S3_ENDPOINT_URL=http://localhost:9100
AWS_S3_BUCKET=kizashi-archive
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=kizashi
AWS_SECRET_ACCESS_KEY=kizashi-minio-dev
# ingestion-service base URL (retention-service sweeps/reimports through it, ADR-0011)
INGESTION_SERVICE_URL=http://localhost:8082
# How often retention-sweep-scheduler POSTs /v1/sweep (ADR-0011 point 5's "external scheduling"
# equivalent for docker-compose — a real Kubernetes CronJob replaces this sidecar 1:1 later).
RETENTION_SWEEP_INTERVAL_SECONDS=3600

# Report schedules are evaluated by report-scheduler. The local launcher defaults this to 10s
# for a demonstrable stack; production should use a longer interval appropriate to the cadence.
REPORT_SCHEDULER_INTERVAL_SECONDS=60
# Optional SMTP delivery. Leave REPORT_SMTP_HOST and REPORT_FROM_EMAIL blank to keep generated
# reports in the Console run ledger without attempting email delivery.
REPORT_SMTP_HOST=
REPORT_SMTP_PORT=587
REPORT_SMTP_USERNAME=
REPORT_SMTP_PASSWORD=
REPORT_FROM_EMAIL=

# backup-service (ADR-0055) — reuses the same MinIO/S3-compatible target as retention-service,
# a separate bucket since a whole-database backup has a different lifecycle/owner than archived
# application data. BACKUP_INTERVAL_SECONDS defaults to daily.
BACKUP_S3_BUCKET=kizashi-backups
BACKUP_INTERVAL_SECONDS=86400

# Console UI (ADR-0014) — the backend URLs it proxies authenticated requests to
AUTH_SERVICE_URL=http://localhost:8089
CONFIG_ADMIN_SERVICE_URL=http://localhost:8090
OBSERVABILITY_URL=http://localhost:8092
# Internal address of ingestion-gateway, used for the API Keys admin page (create/list/revoke)
# — distinct from INGESTION_GATEWAY_PUBLIC_URL below, which is what a *deployed connector*
# should point at and may not be reachable from inside this container.
INGESTION_GATEWAY_URL=http://localhost:8081
# The address a *deployed connector* should point at (may be a different host than this
# machine's internal service network — the Agents deploy-script generator uses this as the
# default INGESTION_GATEWAY_URL it prefills, editable per-generation).
INGESTION_GATEWAY_PUBLIC_URL=http://localhost:8081
# action-executor's query endpoint (ADR-0017 follow-up), used by the Record Journey page
ACTION_EXECUTOR_URL=http://localhost:8088
# retention-service, used by the Data Retention page
RETENTION_SERVICE_URL=http://localhost:8091
# egress-gateway, used by the Egress Allowlist page
EGRESS_GATEWAY_URL=http://localhost:8094
# trigger-engine, used by the Triggers page's dry-run "Test" action (ADR-0030)
TRIGGER_ENGINE_URL=http://localhost:8087

# agent-scheduler (ADR-0020): the single platform-wide Ingestion Gateway API key every
# scheduled connector authenticates with (v1 simplification, not a per-Agent key lookup).
# Create a real key via the Console UI's API Keys page and paste it here before enabling any
# scheduled Agent — connectors will fail to authenticate against an empty/placeholder key.
AGENT_SCHEDULER_INGESTION_GATEWAY_API_KEY=

# egress-gateway (ADR-0021): an HTTP CONNECT forward proxy for auditing/allowlisting outbound
# calls this platform makes to external systems. Adoption is opt-in per ADR-0021's
# Consequences — nothing routes through it yet. To opt a connector in, set this on that
# connector's own env and have it configure reqwest::Proxy::all(...).basic_auth(tenant_id,
# connector_id) — see crates/egress-gateway's docs for the exact contract.
# EGRESS_PROXY_URL=http://localhost:3128

# Service bind addresses
BIND_ADDR=0.0.0.0:8080

RUST_LOG=info
